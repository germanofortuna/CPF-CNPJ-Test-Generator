{
  "manifest_version": 3,
  "name": "CPF/CNPJ Test Generator",
  "version": "1.2.0",
  "description": "Gera CPF/CNPJ sintéticos para testes em ambientes de desenvolvimento.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CPF/CNPJ Test Generator",
    "default_popup": "popup.html"
  },
  "icons": {
	  "16": "icons/icon16.png",
	  "32": "icons/icon32.png",
	  "48": "icons/icon48.png",
	  "128": "icons/icon128.png"
  }
}